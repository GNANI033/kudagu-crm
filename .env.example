# -----------------------------
# Kudagu CRM / Inventory (.env)
# -----------------------------

# Required: CRM accepted API key(s) for /api/* calls.
# Use long random key(s), comma-separate to allow rotation.
CRM_SERVICE_API_KEYS=replace_with_crm_api_key_32_plus_chars

# Required: Inventory accepted API key(s) for /api/* calls.
INVENTORY_SERVICE_API_KEYS=replace_with_inventory_api_key_32_plus_chars

# Optional outbound keys:
# - CRM calls Inventory using CRM_OUTBOUND_API_KEY
# - Inventory calls CRM using INVENTORY_OUTBOUND_API_KEY
CRM_OUTBOUND_API_KEY=replace_with_inventory_api_key_32_plus_chars
INVENTORY_OUTBOUND_API_KEY=replace_with_crm_api_key_32_plus_chars

# Backward-compatible shared keys (optional fallback)
# SERVICE_API_KEYS=
# SERVICE_OUTBOUND_API_KEY=

# Internal service URLs (keep internal/private)
CRM_URL=http://127.0.0.1:8000
INVENTORY_URL=http://127.0.0.1:8001

# Runtime
HOST=0.0.0.0
DISABLE_IN_MEMORY_CACHE=1
INVENTORY_BACKOFF_SECONDS=20
MAX_IMPORT_BYTES=5242880
ALLOW_PRIVATE_AI_BASE_URL=0

# CORS (if needed for trusted cross-origin callers)
CORS_ALLOWED_ORIGINS=https://crm.hopit-labs.com,https://inventory.hopit-labs.com

# -----------------------------
# UI Helper examples are in:
# - ui_helper/.env.crm.example
# - ui_helper/.env.inventory.example
# -----------------------------
